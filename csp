# Dynamic CSP Graph Coloring

def is_safe(node, color, assignment, graph):
    for neighbor in graph[node]:
        if neighbor in assignment and assignment[neighbor] == color:
            return False
    return True

def solve_csp(graph, colors, assignment):
    # If all nodes are assigned
    if len(assignment) == len(graph):
        return assignment

    # Select unassigned node
    for node in graph:
        if node not in assignment:
            break

    # Try all colors
    for color in colors:
        if is_safe(node, color, assignment, graph):
            assignment[node] = color

            result = solve_csp(graph, colors, assignment)
            if result:
                return result

            # Backtrack
            del assignment[node]

    return None


# ----------- Dynamic Input ------------

n = int(input("Enter number of nodes: "))
nodes = []

print("Enter node names:")
for _ in range(n):
    nodes.append(input())

graph = {node: [] for node in nodes}

e = int(input("Enter number of edges: "))
print("Enter edges (node1 node2):")
for _ in range(e):
    u, v = input().split()
    graph[u].append(v)
    graph[v].append(u)

c = int(input("Enter number of colors: "))
colors = []

print("Enter colors:")
for _ in range(c):
    colors.append(input())

# ----------- Solve CSP ------------
solution = solve_csp(graph, colors, {})

if solution:
    print("Solution Found:")
    for node in solution:
        print(node, "->", solution[node])
else:
    print("No solution exists!")
